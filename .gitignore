# =============================================================================
# TechnoDexterous Chatbot — .gitignore
# Stack: Python 3 / Flask / Vanilla JS
# =============================================================================


# =============================================================================
# Python — Byte Code & Compiled Files
# =============================================================================
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd

# C Extensions
*.so

# =============================================================================
# Python — Distribution & Packaging
# =============================================================================
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# =============================================================================
# Python — Virtual Environments
# =============================================================================
.venv/
venv/
env/
ENV/
env.bak/
venv.bak/
.virtualenv/

# =============================================================================
# Python — Testing & Coverage
# =============================================================================
htmlcov/
.tox/
.nox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
*.py,cover
.hypothesis/
.pytest_cache/
cover/

# =============================================================================
# Python — Installers & Logs
# =============================================================================
pip-log.txt
pip-delete-this-directory.txt

# =============================================================================
# Python — PyInstaller
# =============================================================================
*.manifest
*.spec

# =============================================================================
# Python — Misc Tooling
# =============================================================================
.pdm.toml
.pdm-python
.pybuilder/
__pypackages__/
.scrapy
.ipynb_checkpoints
profile_default/
ipython_config.py

# Celery
celerybeat-schedule
celerybeat.pid

# SageMath
*.sage.py

# =============================================================================
# Flask — Runtime Files
# =============================================================================
instance/
.webassets-cache

# =============================================================================
# Environment & Secrets — NEVER COMMIT THESE
# =============================================================================
.env
.env.*
!.env.example
*.env
secrets.json
config.local.py
local_settings.py

# =============================================================================
# Logs
# =============================================================================
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pip-log.txt

# =============================================================================
# Databases (local dev)
# =============================================================================
*.db
*.sqlite
*.sqlite3
db.sqlite3
db.sqlite3-journal

# =============================================================================
# OS-Specific Files
# =============================================================================

# macOS
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
.AppleDouble
.LSOverride
Icon?

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
Desktop.ini
$RECYCLE.BIN/
*.lnk

# Linux
*~

# =============================================================================
# IDE & Editor Files
# =============================================================================

# VS Code
.vscode/
*.code-workspace

# JetBrains (PyCharm, WebStorm, etc.)
.idea/
*.iml
*.iws
*.ipr
out/
.idea_modules/

# Sublime Text
*.sublime-project
*.sublime-workspace

# Vim / Neovim
*.swp
*.swo
*.swn
.netrwhist

# Emacs
*~
\#*\#
/.emacs.desktop
/.emacs.desktop.lock
*.elc
auto-save-list
tramp

# General editor backup files
.project
.settings/
.classpath
*.bak
*.tmp

# =============================================================================
# Node / JavaScript (if tooling is ever added)
# =============================================================================
node_modules/
.npm/
.yarn/
.pnp.*

# =============================================================================
# Build Artifacts
# =============================================================================
dist/
build/
out/
target/

# =============================================================================
# Documentation Build
# =============================================================================
docs/_build/
site/

# =============================================================================
# Miscellaneous
# =============================================================================
*.pid
*.seed
*.pid.lock
*.gz
*.zip
*.tar
